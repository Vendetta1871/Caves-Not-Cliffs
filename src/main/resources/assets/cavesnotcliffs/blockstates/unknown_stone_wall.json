{
  "multipart": [
    { "when": { "up": "true" },    "apply": { "model": "cavesnotcliffs:unknown_stone_wall_post" } },
    { "when": { "north": "true" }, "apply": { "model": "cavesnotcliffs:unknown_stone_wall", "uvlock": true } },
    { "when": { "south": "true" }, "apply": { "model": "cavesnotcliffs:unknown_stone_wall", "y": 180, "uvlock": true } },
    { "when": { "west": "true" },  "apply": { "model": "cavesnotcliffs:unknown_stone_wall", "y": 270, "uvlock": true } },
    { "when": { "east": "true" },  "apply": { "model": "cavesnotcliffs:unknown_stone_wall", "y": 90, "uvlock": true } }
  ]
}
